
//uses elementary dp technique
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;


bool subset(ll a[], ll n, ll sum){
    bool t[n+1][sum + 1];

    for(int i = 0; i < n; i++){
        t[i][0] = true;
    }

    for(int i = 1; i <= sum; ++i){
        t[0][i] = false;
    }

    for(int i = 1; i <= n; i++){
        for(int j = 1; j <= sum; ++j){
            if(a[i-1]> j){
                t[i][j] = t[i-1][j];
            }else{
                t[i][j] = t[i - 1][j - a[i]] || t[i - 1][j];
                //|| changes to + in knapsack cause we are maximizing weight
            }
        }
    }

    return t[n][sum];
}

int main(){

    ll n;
    cin >> n;
    ll arr[n]; ll sum = 0;

    for(int i = 0; i < n; ++i){
        cin >> arr[i];
        sum += arr[i];
    } 

    if(subset(arr,n, sum/2)){
        cout << "YES";
    }else{
        cout << "NO";
    }

}
